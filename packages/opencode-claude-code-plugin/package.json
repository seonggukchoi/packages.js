{
  "name": "@seonggukchoi/opencode-claude-code-plugin",
  "version": "0.2.2",
  "description": "OpenCode plugin helpers for the Claude Code CLI provider",
  "author": "seonggukchoi",
  "license": "MIT",
  "type": "module",
  "engineStrict": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/seonggukchoi/packages.js",
    "directory": "packages/opencode-claude-code-plugin"
  },
  "keywords": [
    "opencode",
    "claude",
    "plugin"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist .tsbuildinfo && tsc -p tsconfig.build.json",
    "lint": "eslint --fix .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:typecheck": "tsc -p tsconfig.check.json --noEmit",
    "typecheck": "pnpm run test:typecheck"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0",
    "zod": ">=4.0.0"
  },
  "dependencies": {
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.0",
    "@types/node": "^24.9.1"
  }
}
