{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@seonggukchoi/opencode-claude-code-plugin"],
  "provider": {
    "claude-code": {
      "name": "Claude Code",
      "npm": "@seonggukchoi/opencode-claude-code-provider",
      "options": {
        "pathToClaudeCodeExecutable": "claude"
      },
      "models": {
        "opus": {
          "id": "claude-opus",
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "name": "Claude Opus",
          "options": {
            "effort": "medium"
          },
          "reasoning": true,
          "tool_call": true,
          "variants": {
            "low": {
              "effort": "low"
            },
            "medium": {
              "effort": "medium"
            },
            "high": {
              "effort": "high"
            },
            "max": {
              "effort": "max"
            }
          }
        },
        "sonnet": {
          "id": "claude-sonnet",
          "limit": {
            "context": 1000000,
            "output": 64000
          },
          "name": "Claude Sonnet",
          "options": {
            "effort": "medium"
          },
          "reasoning": true,
          "tool_call": true,
          "variants": {
            "low": {
              "effort": "low"
            },
            "medium": {
              "effort": "medium"
            },
            "high": {
              "effort": "high"
            }
          }
        },
        "haiku": {
          "id": "claude-haiku",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "name": "Claude Haiku",
          "options": {
            "effort": "low"
          },
          "reasoning": true,
          "tool_call": true,
          "variants": {
            "low": {
              "effort": "low"
            },
            "medium": {
              "effort": "medium"
            }
          }
        }
      }
    }
  }
}
