{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@seonggukchoi/opencode-claude-code-plugin"],
  "provider": {
    "claude-code": {
      "name": "Claude Code",
      "npm": "@seonggukchoi/opencode-claude-code-provider",
      "options": {
        "pathToClaudeCodeExecutable": "claude"
      },
      "models": {
        "opus": {
          "id": "claude-opus-4-6[1m]",
          "cost": {
            "input": 5,
            "output": 25,
            "cache_read": 0.5,
            "cache_write": 6.25
          },
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "name": "Claude Opus",
          "options": {
            "effort": "medium"
          },
          "reasoning": true,
          "tool_call": true,
          "variants": {
            "low": {
              "effort": "low"
            },
            "medium": {
              "effort": "medium"
            },
            "high": {
              "effort": "high"
            },
            "max": {
              "effort": "max"
            }
          }
        },
        "sonnet": {
          "id": "claude-sonnet-4-6[1m]",
          "cost": {
            "input": 3,
            "output": 15,
            "cache_read": 0.3,
            "cache_write": 3.75
          },
          "limit": {
            "context": 1000000,
            "output": 64000
          },
          "name": "Claude Sonnet",
          "options": {
            "effort": "medium"
          },
          "reasoning": true,
          "tool_call": true,
          "variants": {
            "low": {
              "effort": "low"
            },
            "medium": {
              "effort": "medium"
            },
            "high": {
              "effort": "high"
            }
          }
        },
        "haiku": {
          "id": "claude-haiku-4-5",
          "cost": {
            "input": 1,
            "output": 5,
            "cache_read": 0.1,
            "cache_write": 1.25
          },
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "name": "Claude Haiku",
          "options": {
            "effort": "low"
          },
          "reasoning": true,
          "tool_call": true,
          "variants": {
            "low": {
              "effort": "low"
            },
            "medium": {
              "effort": "medium"
            }
          }
        }
      }
    }
  }
}
